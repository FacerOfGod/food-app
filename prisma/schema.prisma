generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  createdAt      DateTime        @default(now())
  hostedSessions Session[]       @relation("HostedSessions")
  memberships    SessionMember[]
  votes          Vote[]
  proposedDishes Dish[]          @relation("ProposedDishes")
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  name      String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Session {
  id        String          @id @default(cuid())
  name      String
  hostId    String
  host      User            @relation("HostedSessions", fields: [hostId], references: [id])
  createdAt DateTime        @default(now())
  members   SessionMember[]
  dishes    Dish[]
  votes     Vote[]
}

model SessionMember {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  joinedAt  DateTime @default(now())

  @@unique([sessionId, userId])
}

model Dish {
  id        String   @id @default(cuid())
  name      String
  category  String?
  imageUrl  String?
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  proposerId String?
  proposer   User?    @relation("ProposedDishes", fields: [proposerId], references: [id])
  order      Int      @default(0)
  votes      Vote[]
  createdAt  DateTime @default(now())
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  dishId    String
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  rating    Int
  createdAt DateTime @default(now())

  @@unique([userId, dishId, sessionId])
}
